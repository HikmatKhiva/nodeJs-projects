<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') -%>
  <body class="font-roboto">
    <%- include('partials/header') -%>
    <main>
      <div class="xl:w-[1200px] md:w-4/5 mx-auto mt-10">
        <h1 class="text-4xl"><%= article.title %></h1>
        <article class="bg-light-main px-4 py-6 min-h-96 rounded-lg mt-7">
          <p class="opacity-70 mb-3"> <%= new Date(article.date).toLocaleDateString("en-GB", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric"
                  }) %></p>
          <p class="text-lg">
          <%= article.content %>
          </p>
        </article>
      </div>
    </main>
  </body>
</html>